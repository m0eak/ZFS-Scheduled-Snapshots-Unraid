<?php
require_once '/usr/local/emhttp/plugins/zfs.scheduled.snapshots/include/common.php';

// Define available frequencies
$frequencies = [
    '5min' => '5 Minutes',
    '15min' => '15 Minutes',
    'hourly' => 'Hourly',
    'daily' => 'Daily',
    'weekly' => 'Weekly',
    'monthly' => 'Monthly'
];

// Get all datasets
$allDatasets = [];
$result = ZfsScheduledSnapshots::exec("zfs list -H -o name -t filesystem,volume");
if (!empty($result['output'])) {
    foreach ($result['output'] as $line) {
        $allDatasets[] = trim($line);
    }
}

// Get current configuration for all datasets
$datasetConfigs = [];
$stats = [
    'total' => count($allDatasets),
    'enabled' => 0,
    'snapshots' => 0,
    'latest_dataset' => null,
    'latest_snapshot' => null,
    'latest_time' => 0,
];

foreach ($allDatasets as $ds) {
    // Get properties
    $props = ZfsScheduledSnapshots::exec("zfs get -H -o property,value com.sun:auto-snapshot,com.sun:auto-snapshot:frequency,com.sun:auto-snapshot:keep,com.sun:auto-snapshot:time,com.sun:auto-snapshot:day,com.sun:auto-snapshot:readonly,com.sun:auto-snapshot:retain-days $ds");
    
    $config = [
        'name' => $ds,
        'enabled' => false,
        'frequency' => 'daily',
        'keep' => 31,
        'time' => '00:00',
        'day' => 1,
        'readonly' => false,
        'retain_days' => 0,
        'latest_snapshot' => 'None',
        'latest_time' => 0
    ];

    if (!empty($props['output'])) {
        foreach ($props['output'] as $line) {
            $parts = explode("\t", $line);
            if (count($parts) < 2) continue;
            
            $prop = $parts[0];
            $val = $parts[1];
            
            if ($prop === 'com.sun:auto-snapshot') $config['enabled'] = ($val === 'true');
            if ($prop === 'com.sun:auto-snapshot:frequency' && $val !== '-') $config['frequency'] = $val;
            if ($prop === 'com.sun:auto-snapshot:keep' && $val !== '-') $config['keep'] = intval($val);
            if ($prop === 'com.sun:auto-snapshot:time' && $val !== '-') $config['time'] = $val;
            if ($prop === 'com.sun:auto-snapshot:day' && $val !== '-') $config['day'] = intval($val);
            if ($prop === 'com.sun:auto-snapshot:readonly' && $val !== '-') $config['readonly'] = ($val === 'true');
            if ($prop === 'com.sun:auto-snapshot:retain-days' && $val !== '-') $config['retain_days'] = intval($val);
        }
    }
    
    // Get latest snapshot info for display
    if ($config['enabled']) {
        $stats['enabled']++;
        $latest = ZfsScheduledSnapshots::getLatestSnapshot($ds);
        if ($latest) {
              $config['latest_snapshot'] = date('Y-m-d H:i:s', $latest['timestamp']);
              $config['latest_time'] = $latest['timestamp'];
              if ($latest['timestamp'] > $stats['latest_time']) {
                  $stats['latest_dataset'] = $ds;
                  $stats['latest_snapshot'] = $config['latest_snapshot'];
                  $stats['latest_time'] = $latest['timestamp'];
              }
        }
    }

    $datasetConfigs[] = $config;
}

usort($datasetConfigs, function ($a, $b) {
    if ($a['enabled'] !== $b['enabled']) {
        return $a['enabled'] ? -1 : 1;
    }

    return strcasecmp($a['name'], $b['name']);
});

function zss_page_schedule_label($dataset, $frequencies) {
    $label = $frequencies[$dataset['frequency']] ?? $dataset['frequency'];

    if ($dataset['frequency'] === 'daily') {
        return $label . ' @ ' . $dataset['time'];
    }

    if ($dataset['frequency'] === 'weekly') {
        $days = [1=>'Mon', 2=>'Tue', 3=>'Wed', 4=>'Thu', 5=>'Fri', 6=>'Sat', 7=>'Sun'];
        return $label . ' · ' . ($days[$dataset['day']] ?? $dataset['day']) . ' @ ' . $dataset['time'];
    }

    if ($dataset['frequency'] === 'monthly') {
        return $label . ' · day ' . $dataset['day'] . ' @ ' . $dataset['time'];
    }

    return $label;
}
?>

